# API Ключ для CoinMarketCap
CMC_API_KEY=your_api_key_here

# Тип используемого хранилища: json или sqlite
STORAGE=json

# Провайдер для валидации символов: coingecko или coinmarketcap
CRYPTO_PROVIDER=coingecko

# Настройки для DJANGO
DEBUG=True
SECRET_KEY=your_secret_key_here
DB_NAME=crypto_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432
# API Ключ для CoinMarketCap (опционально, нужен только при CRYPTO_PROVIDER=cmc)
CMC_API_KEY=your_api_key_here

# Тип используемого хранилища для legacy CLI (src/main.py): json или sqlite
STORAGE=json

# Провайдер для валидации символов: coingecko или coinmarketcap
CRYPTO_PROVIDER=coingecko

# Django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=your_secret_key_here

# PostgreSQL
# В docker-compose: DB_HOST=db. Для локального запуска без docker — DB_HOST=127.0.0.1.
DB_NAME=crypto_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=db
DB_PORT=5432

# Celery
# В docker-compose: redis://redis:6379/0. Локально без docker — redis://127.0.0.1:6379/0.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
